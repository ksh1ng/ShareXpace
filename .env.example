OPENAI_API_KEY=
# Free Gemini Developer API key used only for semantic embeddings, never generation.
GEMINI_API_KEY=
# auto prefers Gemini, then OpenAI, then local lexical matching. Also accepts gemini, openai, lexical.
RELAY_EMBEDDING_PROVIDER=auto
RELAY_APP_MODE=production
RELAY_WORKSPACE_ID=RoamTogether
RELAY_WORKSPACE_NAME=RoamTogether
RELAY_SEMANTIC_CACHE_THRESHOLD=0.78
RELAY_SEMANTIC_EMBEDDING_THRESHOLD=0.80
RELAY_LEXICAL_CACHE_THRESHOLD=0.88
RELAY_RAG_THRESHOLD=0.42
RELAY_DEFAULT_TTL_HOURS=24
RELAY_TOKEN_ESTIMATE_TTL_SECONDS=300
RELAY_MAX_OUTPUT_TOKENS=1200
RELAY_MAX_INPUT_TOKENS=100000
RELAY_ALLOW_LOCAL_ANONYMOUS=false
# Hackathon demo: MCP clients join by putting the Dashboard Workspace ID in the MCP URL.
RELAY_MCP_JOIN_MODE=open
# Optional stricter deployment mode: set RELAY_MCP_JOIN_MODE=bearer_token and configure this JSON map.
RELAY_MCP_ACCESS_TOKENS=
RELAY_AGENT_ONLINE_WINDOW_SECONDS=120
