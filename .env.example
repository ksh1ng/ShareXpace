OPENAI_API_KEY=
RELAY_APP_MODE=production
RELAY_WORKSPACE_ID=relay-production
RELAY_SEMANTIC_CACHE_THRESHOLD=0.78
RELAY_RAG_THRESHOLD=0.42
RELAY_DEFAULT_TTL_HOURS=24
RELAY_TOKEN_ESTIMATE_TTL_SECONDS=300
RELAY_MAX_OUTPUT_TOKENS=1200
RELAY_MAX_INPUT_TOKENS=100000
RELAY_ALLOW_LOCAL_ANONYMOUS=false
# JSON object: bearer token -> workspace member display name. Keep real tokens in hosted secrets.
RELAY_MCP_ACCESS_TOKENS={"replace-with-long-random-token":"Demo Member"}
